{
  "name": "qxf-video",
  "version": "1.0.0",
  "description": "面向 Windows 10/11 的多平台视频发布工作台",
  "author": "QXF19",
  "license": "MIT",
  "homepage": "https://github.com/QXF19/qxf-video#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/QXF19/qxf-video.git"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "icon": "node scripts/generate-icon.mjs",
    "desktop": "electron .",
    "pack": "npm run icon && electron-builder --dir --win x64",
    "dist:win": "npm run icon && electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "cn.qxf.batchvideouploader",
    "productName": "批量视频上传",
    "copyright": "Copyright © 2026 QXF19",
    "artifactName": "QXF-Video-Setup-${version}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "manifest.webmanifest",
      "service-worker.js",
      "electron/**/*",
      "build/icon.png",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "批量视频上传",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
